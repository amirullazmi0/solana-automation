generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id                      Int         @id @default(autoincrement())
  tokenMint               String
  symbol                  String?     @default("UNKNOWN")
  slotNumber              Int
  entryPrice              Float
  highestPrice            Float
  trailingStopPrice       Float
  exitPrice               Float?
  exitReason              String?
  profitUsd               Float?
  entryLiquidity          Float?
  entryMarketCap          Float?
  status                  TradeStatus @default(OPEN)
  amountInSol             Float
  buyTxHash               String?
  sellTxHash              String?
  feesPaid                Float?
  creatorAddress          String?
  topHolderAddress        String?
  initialCreatorBalance   Float?
  initialTopHolderBalance Float?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  slTriggeredAt           DateTime?

  @@index([status])
  @@index([tokenMint, createdAt])
}

enum WatchlistStatus {
  PENDING
  TRADED
  FAILED
}

model Watchlist {
  id            Int             @id @default(autoincrement())
  tokenMint     String          @unique
  symbol        String?
  mcap          Float?
  liquidity     Float?
  volumeSurge   Float?
  checkCount    Int             @default(0)
  lastCheckedAt DateTime        @default(now())
  createdAt     DateTime        @default(now())
  status        WatchlistStatus @default(PENDING)
  reason        String?
}
