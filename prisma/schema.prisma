generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum TradeMode {
  LIVE
  PAPER
}

enum TelegramChatType {
  PRIVATE
  GROUP
  SUPERGROUP
  CHANNEL
}

enum TelegramChatStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model TelegramChat {
  id          Int                 @id @default(autoincrement())
  chatId      String              @unique
  chatType    TelegramChatType
  title       String?
  username    String?
  status      TelegramChatStatus   @default(ACTIVE)
  lastSeenAt  DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  walletVault TelegramWalletVault?
  settings    TelegramChatSetting?
  trades      Trade[]

  @@index([status, chatType])
  @@index([lastSeenAt])
}

model TelegramWalletVault {
  id                  Int           @id @default(autoincrement())
  telegramChatId      Int           @unique
  publicKey           String        @unique
  encryptedSecretKey  String
  initializationVector String
  authTag             String
  keyVersion          Int           @default(1)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  chat                TelegramChat  @relation(fields: [telegramChatId], references: [id], onDelete: Cascade)
}

model TelegramChatSetting {
  id               Int          @id @default(autoincrement())
  telegramChatId   Int          @unique
  totalSlots       Int          @default(2)
  positionSizeUsd  Float        @default(5)
  slippageOnSol    Float        @default(0.005)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  chat             TelegramChat  @relation(fields: [telegramChatId], references: [id], onDelete: Cascade)
}

model Trade {
  id                      Int         @id @default(autoincrement())
  telegramChatId          Int?
  tokenMint               String
  symbol                  String?     @default("UNKNOWN")
  slotNumber              Int
  entryPrice              Float
  highestPrice            Float
  trailingStopPrice       Float
  exitPrice               Float?
  exitReason              String?
  profitUsd               Float?
  entryLiquidity          Float?
  entryMarketCap          Float?
  solPriceAtEntry         Float?
  entryValueUsd           Float?
  status                  TradeStatus @default(OPEN)
  mode                    TradeMode   @default(LIVE)
  amountInSol             Float
  buyTxHash               String?
  sellTxHash              String?
  feesPaid                Float?
  totalFeesSol            Float?
  creatorAddress          String?
  topHolderAddress        String?
  initialCreatorBalance   Float?
  initialTopHolderBalance Float?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  slTriggeredAt           DateTime?
  partialTakeProfitAt     DateTime?
  targetTakeProfit        Float?
  targetStopLoss          Float?
  targetTrailingDistance  Float?
  telegramChat            TelegramChat? @relation(fields: [telegramChatId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([mode, status])
  @@index([tokenMint, createdAt])
  @@index([telegramChatId, status, mode])
}

enum WatchlistStatus {
  PENDING
  TRADED
  FAILED
}

model Watchlist {
  id            Int             @id @default(autoincrement())
  tokenMint     String          @unique
  symbol        String?
  mcap          Float?
  liquidity     Float?
  volumeSurge   Float?
  volScore      Float?
  zScore        Float?
  priceChange1h Float?
  isPumpFun     Boolean         @default(false)
  pairCreatedAt DateTime?
  checkCount    Int             @default(0)
  lastCheckedAt DateTime        @default(now())
  createdAt     DateTime        @default(now())
  status        WatchlistStatus @default(PENDING)
  reason        String?

  @@index([status, lastCheckedAt])
  @@index([createdAt, status])
  @@index([pairCreatedAt, createdAt])
}

model CreatorProfile {
  address       String   @id
  tokensCreated Int      @default(1)
  ruggedTokens  Int      @default(0)
  riskScore     Float    @default(0)
  isBlacklisted Boolean  @default(false)
  reason        String?
  tags          String[] @default([])
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isBlacklisted])
  @@index([riskScore])
}
