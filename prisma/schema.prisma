generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id                Int         @id @default(autoincrement())
  tokenMint         String
  symbol            String?     @default("UNKNOWN")
  slotNumber        Int
  entryPrice        Float
  highestPrice      Float
  trailingStopPrice Float
  exitPrice         Float?
  profitUsd         Float?
  entryLiquidity    Float?
  entryMarketCap    Float?
  status            TradeStatus @default(OPEN)
  amountInSol       Float
  creatorAddress        String?
  topHolderAddress      String?
  initialCreatorBalance   Float?
  initialTopHolderBalance Float?
  createdAt             DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Watchlist {
  id            Int      @id @default(autoincrement())
  tokenMint     String   @unique
  symbol        String?
  mcap          Float?
  liquidity     Float?
  volumeSurge   Float?
  lastCheckedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  status        String   @default("PENDING") // PENDING, TRADED, FAILED
  reason        String?
}
