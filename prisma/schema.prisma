generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id                Int         @id @default(autoincrement())
  tokenMint         String
  symbol            String?     @default("UNKNOWN")
  slotNumber        Int
  entryPrice        Float
  highestPrice      Float
  trailingStopPrice Float
  exitPrice         Float?
  profitUsd         Float?
  entryLiquidity    Float?
  entryMarketCap    Float?
  status            TradeStatus @default(OPEN)
  amountInSol       Float
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}
