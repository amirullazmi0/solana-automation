# Configuration & Budget
TOTAL_CAPITAL=26
RESERVE_AMOUNT=5
TOTAL_SLOTS=3
POSITION_SIZE_USD=7
STOP_LOSS_PERCENT=25.0
TRAILING_DISTANCE_PERCENT=0.3
SLIPPAGE_BPS=2000
MIN_LIQUIDITY_USD=5000
MIN_VOLUME_USD=1500
MIN_BUY_COUNT=12
MIN_VL_RATIO=1.8
MIN_VOLUME_MCAP_RATIO=0.07

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/solanabot?schema=public"

# Solana RPC Endpoints
# Use endpoints that support WSS (like Helius or QuickNode)
RPC_ENDPOINT="https://api.mainnet-beta.solana.com"
WSS_ENDPOINT="wss://api.mainnet-beta.solana.com"

# Telegram Bot Integration
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# Wallet Configuration (DO NOT SHARE OR COMMIT)
PRIVATE_KEY="YOUR_BASE58_PRIVATE_KEY_HERE"

# Jupiter API (Metis/Paid)
JUPITER_API_KEY="your_jupiter_api_key"
