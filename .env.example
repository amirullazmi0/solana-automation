PORT=3005
# 🏦 SOLANA TREND FOLLOWER BOT - EXAMPLE CONFIGURATION
# Copy this file to .env and fill in your values.
# 🐋 Mode: 'whale' = Whale / Trend-Following (DexScreener + social/narrative gate), 'micin' = Micin Sniper (PumpPortal + DexScreener)
BOT_MODE=micin
APP_MODE=development

# ==========================================
# 💰 BUDGET & RISK MANAGEMENT
# ==========================================
TOTAL_CAPITAL=20          # Total modal dalam USD
RESERVE_AMOUNT=10         # Sisa dana yang TIDAK boleh disentuh (safety net)
TOTAL_SLOTS=2             # Jumlah posisi yang bisa dibuka secara bersamaan
POSITION_SIZE_USD=3       # Ukuran setiap posisi (USD per trade)
SLIPPAGE_BPS=500          # Slippage tolerance (500 = 5%)

# ==========================================
# 📈 TRADING STRATEGY (TAKE PROFIT / STOP LOSS)
# ==========================================
TAKE_PROFIT_PERCENT=30.0          # Target profit sebelum trailing stop aktif
STOP_LOSS_PERCENT=25.0            # Batas kerugian maksimal sebelum auto-sell
TRAILING_DISTANCE_PERCENT=5.0     # Jarak trailing stop dari harga tertinggi
DISABLE_SL_PATIENCE=true          # Nonaktifkan delay 5 menit stop loss untuk koin standar

# ==========================================
# 🔍 SCANNER & DISCOVERY FILTERS
# ==========================================
MIN_MCAP=5000             # Minimum Market Cap (USD) — koin dibawah ini terlalu kecil
MAX_MCAP=300000           # Maximum Market Cap (USD) — diatas ini sudah "too established"
MIN_AGE_HOURS=0.5        # Minimum umur token (jam) — filter koin yang stabil
MAX_AGE_HOURS=24.0        # Maximum umur token (jam) — koin > 24 jam biasanya sudah kehilangan momentum
MIN_BUY_CONFIDENCE=0.60   # Minimum rasio buyer vs seller (0.60 = 60% pembeli) — memastikan ada demand
RUGCHECK_MIN_SAFETY_INDEX=0.80  # Minimum safety index dari RugCheck (0.80 = Sangat aman, LP burned)

# Base Liquidity & Volume
MIN_LIQUIDITY_USD=7500    # Minimum liquidity di pool (USD) — dibawah ini terlalu tipis, slippage gede
MIN_VOLUME_USD=500        # Minimum volume 5 menit terakhir (USD)
MIN_BUY_COUNT=5           # Minimum jumlah buyer dalam 5 menit terakhir

# Advanced Ratios & Surge
MIN_VL_RATIO=0.1                  # Volume/Liquidity ratio minimum
MIN_VOLUME_MCAP_RATIO=0.05        # Volume/MCap ratio — seberapa aktif trading relatif terhadap ukuran koin
ANALYZER_MIN_VOL_SCORE=0.02       # VoL Score minimum (Velocity of Liquidity) — kecepatan uang masuk pool
ANALYZER_MIN_Z_SCORE=1.5          # Z-Score minimum — deteksi anomali volume (1.5 = volume mulai abnormal)
ANALYZER_MIN_VOLUME_SURGE=1.5     # Volume surge minimum (1.5 = volume saat ini >= rata-rata 1.5x)

# ==========================================
# 🚀 ESTABLISHED REBOUND & CTO STRATEGY
# ==========================================
ESTABLISHED_MIN_AGE_HOURS=24
ESTABLISHED_MAX_AGE_HOURS=72
ESTABLISHED_MIN_BUYS=5
MIN_ESTABLISHED_LIQUIDITY=3000
MAX_ESTABLISHED_MCAP=200000
REBOUND_PRICE_DROP_PCT=-50
VOLUME_SPIKE_RATIO=0.25
BUY_SELL_RATIO_THRESHOLD=1.5


# ==========================================
# 💓 SCANNER PERFORMANCE (Turbo Mode)
# ==========================================
SCANNER_MAX_CONCURRENT=20         # Max token yang bisa dipantau bersamaan
SCANNER_POLLING_INTERVAL=3000     # Interval polling DexScreener (ms) — 3 detik
SCANNER_RADAR_INTERVAL=10000      # Interval re-check watchlist dari DB (ms) — 10 detik
SCANNER_HEARTBEAT_INTERVAL=30000  # Interval heartbeat log (ms) — 30 detik
SCANNER_RECHECK_DELAY_MS=5000     # Delay antara setiap re-check token (ms)
ANALYZER_MAX_SCAN_DURATION_MIN=15 # Berapa lama (menit) token dipantau sebelum timeout

# ==========================================
# ⚡ TRADE EXECUTION & RPC
# ==========================================
TRADE_TIMEOUT_MS=15000            # Timeout untuk setiap request Jupiter (ms)
TRADE_MAX_RETRIES=5               # Maksimum retry jika swap gagal
TRADE_PRIORITY_MULTIPLIER=3       # Multiplier priority fee (3x = gas lebih tinggi biar cepat masuk)
MAX_PRICE_IMPACT_PCT=10.0         # Maksimum price impact untuk BUY (%)

# Jito MEV Integration (Anti-Sandwich & Guaranteed Execution)
USE_JITO=true
JITO_TIP_SOL=0.001
JITO_BLOCK_ENGINE_URL="https://mainnet.block-engine.jito.wtf/api/v1/bundles"

TRADE_DUST_THRESHOLD=0.000001     # Threshold saldo minimum yang dianggap "dust" (diabaikan)
COOLDOWN_WIN_HOURS=6              # Cooldown re-buy token setelah trade profit
COOLDOWN_LOSS_HOURS=24            # Cooldown re-buy token setelah trade rugi

# ==========================================
# Risk Circuit Breakers (LIVE trades only)
# ==========================================
# Blocks new buys when thresholds are hit. Set 0 to disable.
DAILY_MAX_LOSS_USD=0
MAX_CONSECUTIVE_LOSSES=0
MAX_DRAWDOWN_PCT=0

# Force-disable buying until this ISO time (UTC recommended), example:
# DISABLE_BUY_UNTIL="2026-05-30T00:00:00Z"
DISABLE_BUY_UNTIL=""

# Apply risk breakers to manual buys too (Telegram manual buy)
RISK_APPLY_TO_MANUAL=false

# RPC Endpoints (Helius/Private — WAJIB pakai RPC berbayar untuk kecepatan)
SOLANA_RPC_URL="https://your-helius-rpc-url.com/?api-key=YOUR_HELIUS_API_KEY"
RPC_ENDPOINT="https://your-rpc-endpoint.com"
WSS_ENDPOINT="wss://your-wss-endpoint.com"
HELIUS_WEBHOOK_SECRET="your-helius-webhook-secret"

# Jupiter API Key (Paid Metis — untuk akses prioritas swap)
JUPITER_API_KEY="your-jupiter-api-key"

# ==========================================
# 📱 INTEGRATION & SECURITY
# ==========================================
# Telegram Bot (untuk notifikasi BUY/SELL/Watchlist)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"
TELEGRAM_CHAT_IDS="1482408355,-1003613922447"

# API Security (Required for /buy endpoint — mencegah orang lain trigger buy)
API_SECRET_KEY="your-secret-key"

# Wallet (DO NOT SHARE — Private key wallet Solana dalam format Base58)
WALLET_ENCRYPTION_KEY="your-32-byte-encryption-secret"

# Database (Prisma — PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public&sslmode=disable"
DB_FAIL_FAST=true

# ==========================================
# 🧠 AI CONVICTION ENGINE (GPT / Grok)
# ==========================================
OPENAI_API_KEY="your-openai-api-key"
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"
AI_CONVICTION_THRESHOLD=75.0
WHALE_SIGNAL_SCORE_FLOOR=55

