# 🏦 SOLANA TREND FOLLOWER BOT - EXAMPLE CONFIGURATION
# Copy this file to .env and fill in your values.

# ==========================================
# 💰 BUDGET & RISK MANAGEMENT
# ==========================================
TOTAL_CAPITAL=20
RESERVE_AMOUNT=8
TOTAL_SLOTS=4
POSITION_SIZE_USD=3
SLIPPAGE_BPS=300

# ==========================================
# 📈 TRADING STRATEGY (TAKE PROFIT / STOP LOSS)
# ==========================================
TAKE_PROFIT_PERCENT=30.0
STOP_LOSS_PERCENT=25.0
TRAILING_DISTANCE_PERCENT=5.0

# ==========================================
# 🔍 SCANNER & DISCOVERY FILTERS
# ==========================================
MIN_MCAP=10000
MAX_MCAP=300000
MIN_AGE_HOURS=1
MIN_BUY_CONFIDENCE=0.7

# Base Liquidity & Volume
MIN_LIQUIDITY_USD=5000
MIN_VOLUME_USD=1000
MIN_BUY_COUNT=20

# Advanced Ratios
MIN_VL_RATIO=0.1
MIN_VOLUME_MCAP_RATIO=0.05
ANALYZER_MIN_VOL_SCORE=0.05
ANALYZER_MIN_Z_SCORE=2.5
ANALYZER_MIN_VOLUME_SURGE=1.5

# ==========================================
# 💓 SCANNER PERFORMANCE (Intervals in ms)
# ==========================================
SCANNER_MAX_CONCURRENT=100
SCANNER_POLLING_INTERVAL=15000
SCANNER_RADAR_INTERVAL=20000
SCANNER_HEARTBEAT_INTERVAL=30000
ANALYZER_MAX_SCAN_DURATION_MIN=10

# ==========================================
# ⚡ TRADE EXECUTION & RPC
# ==========================================
TRADE_TIMEOUT_MS=20000
TRADE_MAX_RETRIES=5
TRADE_PRIORITY_MULTIPLIER=2
TRADE_DUST_THRESHOLD=0.000001

# RPC Endpoints
RPC_ENDPOINT="https://your-rpc-endpoint.com"
WSS_ENDPOINT="wss://your-wss-endpoint.com"

# Jupiter API Key
JUPITER_API_KEY="your-jupiter-api-key"

# ==========================================
# 📱 INTEGRATION & SECURITY
# ==========================================
# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# Wallet (DO NOT SHARE)
PRIVATE_KEY="your-wallet-private-key-bs58"

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
